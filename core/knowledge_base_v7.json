  "reasoning_patterns": {
    "deductive": {
      "description": "General to specific",
      "example": "All men are mortal. Socrates is a man. Therefore, Socrates is mortal.",
      "confidence": "high_when_premises_true"
    },
    "inductive": {
      "description": "Specific to general",
      "example": "Every swan I have seen is white. Therefore, all swans are white.",
      "confidence": "probabilistic"
    },
    "abductive": {
      "description": "Inference to best explanation",
      "example": "The lawn is wet. The best explanation is that it rained.",
      "confidence": "context_dependent"
    },
    "analogical": {
      "description": "Based on similarities",
      "example": "The heart is like a pump. Pumps have valves. Therefore, the heart has valves.",
      "confidence": "depends_on_similarity"
    }
  },
